# pyfx Configuration
# Copy this file to .env and customize as needed:
#   cp .env.example .env
#
# All variables are optional — sensible defaults are provided.
# Prefix: every variable must start with PYFX_

# ---------------------------------------------------------------------------
# Data Directories
# ---------------------------------------------------------------------------

# Where downloaded/generated bar data (CSV, Parquet) is cached.
# Default: ~/.pyfx/data
# PYFX_DATA_DIR=~/.pyfx/data

# NautilusTrader Parquet catalog directory.
# Default: ~/.pyfx/catalog
# PYFX_CATALOG_DIR=~/.pyfx/catalog

# ---------------------------------------------------------------------------
# Strategy Discovery
# ---------------------------------------------------------------------------

# Extra directory to scan for strategy modules (in addition to entry points).
# Any .py file in this directory that subclasses PyfxStrategy will be
# auto-discovered and available via `pyfx strategies` / `pyfx backtest -s`.
# Default: not set (only entry-point strategies are loaded)
# PYFX_STRATEGIES_DIR=/path/to/my/strategies

# ---------------------------------------------------------------------------
# Backtest Defaults
# ---------------------------------------------------------------------------

# Starting account balance in USD.
# Default: 100000
# PYFX_DEFAULT_BALANCE=100000

# Default leverage ratio (e.g. 50 means 50:1).
# Default: 50
# PYFX_DEFAULT_LEVERAGE=50

# ---------------------------------------------------------------------------
# Django Dashboard
# ---------------------------------------------------------------------------

# Path to the SQLite database used by the web dashboard.
# Default: ~/.pyfx/db.sqlite3
# PYFX_DB_PATH=~/.pyfx/db.sqlite3

# Django secret key — CHANGE THIS in production!
# Generate one with: python -c "import secrets; print(secrets.token_urlsafe(50))"
# Default: pyfx-dev-secret-change-in-production
# PYFX_SECRET_KEY=your-random-secret-key-here

# ---------------------------------------------------------------------------
# Interactive Brokers (Paper Trading)
# ---------------------------------------------------------------------------

# IB Gateway / TWS credentials.
# Used by NautilusTrader's DockerizedIBGateway to auto-manage the container.
# PYFX_IB_USERNAME=your_ib_username
# PYFX_IB_PASSWORD=your_ib_password

# IB account ID. Paper accounts start with "DU" (e.g. DU1234567).
# PYFX_IB_ACCOUNT_ID=DU1234567

# IB Gateway connection settings.
# Default host: 127.0.0.1
# Ports: 4002 = paper IBG, 4001 = live IBG, 7497 = paper TWS, 7496 = live TWS
# PYFX_IB_HOST=127.0.0.1
# PYFX_IB_PORT=4002

# API client ID (each connected app needs a unique ID).
# Default: 1
# PYFX_IB_CLIENT_ID=1

# Trading mode: "paper" or "live". Live requires --confirm-live CLI flag.
# Default: paper
# PYFX_IB_TRADING_MODE=paper

# Set to True to block order execution (data-only mode).
# Default: False (orders are allowed)
# PYFX_IB_READ_ONLY_API=False

# Docker image for the IB Gateway container.
# Default: ghcr.io/gnzsnz/ib-gateway:stable
# PYFX_IB_GATEWAY_IMAGE=ghcr.io/gnzsnz/ib-gateway:stable

# ---------------------------------------------------------------------------
# Account
# ---------------------------------------------------------------------------

# Account base currency. Must be USD, CHF, GBP, or EUR.
# Recommendation: USD (matches backtest assumptions for cleanest comparison).
# Default: USD
# PYFX_ACCOUNT_CURRENCY=USD

# ---------------------------------------------------------------------------
# Risk Management
# ---------------------------------------------------------------------------

# Position sizing method: "fixed_fractional" or "atr_based".
# Default: fixed_fractional
# PYFX_RISK_SIZING_METHOD=fixed_fractional

# Percentage of equity to risk per trade.
# Default: 2.0
# PYFX_RISK_POSITION_SIZE_PCT=2.0

# Maximum number of concurrent open positions.
# Default: 3
# PYFX_RISK_MAX_POSITIONS=3

# Maximum units per single position.
# Default: 100000
# PYFX_RISK_MAX_POSITION_SIZE=100000

# Daily loss circuit breaker (in account currency). Trading stops if breached.
# Default: 2000.0
# PYFX_RISK_DAILY_LOSS_LIMIT=2000.0

# Maximum drawdown percentage before auto-stop.
# Default: 10.0
# PYFX_RISK_MAX_DRAWDOWN_PCT=10.0

# NautilusTrader native max notional value per order.
# Default: 500000
# PYFX_RISK_MAX_NOTIONAL_PER_ORDER=500000

# ---------------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------------

# Directory for log files. Default: <data_dir>/logs
# PYFX_LOG_DIR=~/.pyfx/logs
